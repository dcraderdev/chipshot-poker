---
// Static (server-rendered) card. For dynamic dealing use card-svg.js renderCard().
export interface Props {
  rank?: string;
  suit?: 's' | 'h' | 'd' | 'c';
  faceDown?: boolean;
  small?: boolean;
}
const { rank, suit, faceDown = false, small = false } = Astro.props;

const SUIT_GLYPH: Record<string, string> = { s: '♠', h: '♥', d: '♦', c: '♣' };
const isRed = suit === 'h' || suit === 'd';
const w = small ? 44 : 64;
const h = small ? 64 : 92;
const fontSize = small ? 12 : 16;
const pipSize = small ? 14 : 22;
const rankDisplay = rank === 'T' ? '10' : rank;
---
{faceDown || !rank || !suit ? (
  <div class="cs-card cs-card--back" style={`width:${w}px;height:${h}px;`}>
    <div class="cs-card__back-pattern"></div>
  </div>
) : (
  <div
    class="cs-card cs-card--face"
    style={`width:${w}px;height:${h}px;color:${isRed ? 'var(--color-card-red)' : 'var(--color-card-ink)'};`}
  >
    <div class="cs-card__corner cs-card__corner--tl" style={`font-size:${fontSize}px;line-height:1;`}>
      <span class="cs-card__rank">{rankDisplay}</span>
      <span class="cs-card__suit">{SUIT_GLYPH[suit]}</span>
    </div>
    <div class="cs-card__pip" style={`font-size:${pipSize}px;`}>{SUIT_GLYPH[suit]}</div>
    <div class="cs-card__corner cs-card__corner--br" style={`font-size:${fontSize}px;line-height:1;`}>
      <span class="cs-card__rank">{rankDisplay}</span>
      <span class="cs-card__suit">{SUIT_GLYPH[suit]}</span>
    </div>
  </div>
)}
