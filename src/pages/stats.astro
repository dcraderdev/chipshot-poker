---
import PokerLayout from '../layouts/PokerLayout.astro';

const GAMES = [
  { key: 'holdem', label: "Texas Hold'em" },
  { key: 'blackjack', label: 'Blackjack' },
  { key: 'five-card-draw', label: 'Five-Card Draw' },
  { key: 'video-poker', label: 'Video Poker' },
];
---
<PokerLayout
  title="Stats — ChipShot Poker"
  description="Your numbers across every game."
  active="stats"
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="eyebrow">Dashboard</span>
        <h1 class="display text-3xl sm:text-4xl text-parchment mt-3">Your Numbers</h1>
        <p class="text-parchment-soft text-sm mt-2 max-w-xl">
          Live stats from every hand you&rsquo;ve played &mdash; pulled straight from this browser&rsquo;s history.
        </p>
      </div>
      <div class="mono text-xs text-parchment-dim">
        Last hand <span id="last-hand-time" class="text-parchment">&mdash;</span>
      </div>
    </div>
    <div class="gold-rule mt-6"></div>
  </section>

  <!-- OVERALL ROW -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <ul id="overall" class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <li class="panel p-4">
        <p class="stat-label">Total hands</p>
        <p id="kpi-hands" class="mono font-semibold text-2xl mt-1 text-gold-bright numeral">0</p>
        <p class="text-parchment-dim text-xs mt-1">across all games</p>
      </li>
      <li class="panel p-4">
        <p class="stat-label">Net P/L</p>
        <p id="kpi-net" class="mono font-semibold text-2xl mt-1 text-gold-bright numeral">$0</p>
        <p class="text-parchment-dim text-xs mt-1">chip delta lifetime</p>
      </li>
      <li class="panel p-4">
        <p class="stat-label">Win rate</p>
        <p id="kpi-winrate" class="mono font-semibold text-2xl mt-1 text-gold-bright numeral">&mdash;</p>
        <p class="text-parchment-dim text-xs mt-1">excludes pushes</p>
      </li>
      <li class="panel p-4">
        <p class="stat-label">Bankroll</p>
        <p id="kpi-bankroll" class="mono font-semibold text-2xl mt-1 text-gold-bright numeral">$0</p>
        <p class="text-parchment-dim text-xs mt-1">current chips</p>
      </li>
    </ul>
  </section>

  <!-- BANKROLL CHART -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
    <div class="panel p-5 sm:p-7">
      <div class="flex flex-wrap items-end justify-between gap-2 mb-4">
        <div>
          <h2 class="display text-2xl text-parchment">Bankroll trajectory</h2>
          <p class="text-parchment-soft text-sm">Running chip total, hand by hand.</p>
        </div>
        <div class="flex gap-4 mono text-xs">
          <div>
            <span class="stat-label">Peak</span>
            <span id="kpi-peak" class="stat-value ml-2 numeral">&mdash;</span>
          </div>
          <div>
            <span class="stat-label">Low</span>
            <span id="kpi-low" class="ml-2 loss numeral">&mdash;</span>
          </div>
        </div>
      </div>

      <div class="w-full overflow-x-auto">
        <svg id="chart" viewBox="0 0 700 200" class="w-full h-auto min-w-[480px]" role="img" aria-label="Bankroll trajectory line chart">
          <defs>
            <linearGradient id="brArea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#d4af37" stop-opacity="0.35"/>
              <stop offset="100%" stop-color="#d4af37" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <g id="chart-content"></g>
        </svg>
      </div>

      <div class="mt-3 flex flex-wrap justify-between gap-2 mono text-xs text-parchment-dim">
        <span>Hand <span id="chart-x-start" class="text-parchment-soft">0</span></span>
        <span id="chart-caption" class="text-parchment-soft">&mdash;</span>
        <span>Hand <span id="chart-x-end" class="text-parchment-soft">0</span></span>
      </div>
    </div>
  </section>

  <!-- PER-GAME TABLE + RECENT -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 grid lg:grid-cols-3 gap-5">
    <div class="panel p-5 sm:p-7 lg:col-span-2">
      <h2 class="display text-2xl text-parchment">By game</h2>
      <p class="text-parchment-soft text-sm">A breakdown of every table you&rsquo;ve sat at.</p>

      <div class="mt-5 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gold-deep/30">
              <th class="stat-label text-left py-2 pr-3">Game</th>
              <th class="stat-label text-right py-2 px-2">Hands</th>
              <th class="stat-label text-right py-2 px-2">Net</th>
              <th class="stat-label text-right py-2 px-2">Win %</th>
              <th class="stat-label text-right py-2 px-2">Biggest win</th>
              <th class="stat-label text-right py-2 pl-2">Biggest loss</th>
            </tr>
          </thead>
          <tbody id="per-game-rows">
            <tr>
              <td colspan="6" class="text-parchment-dim text-center py-6 text-sm">Loading&hellip;</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="panel p-5 sm:p-7">
      <h2 class="display text-2xl text-parchment">Recent</h2>
      <p class="text-parchment-soft text-sm">Last 10 hand outcomes.</p>

      <div id="recent-strip" class="mt-5 flex flex-wrap gap-2"></div>

      <ul class="mt-5 grid grid-cols-3 gap-2 mono text-xs text-parchment-dim">
        <li class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm" style="background:#4ade80"></span>Win
        </li>
        <li class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm" style="background:#f87171"></span>Loss
        </li>
        <li class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm" style="background:#f0c855"></span>Push
        </li>
      </ul>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pb-20 text-center">
    <p class="text-parchment-soft text-sm">Numbers update in real time as you play. Your data lives only in this browser.</p>
    <div class="mt-4 flex justify-center gap-3 flex-wrap">
      <a href="/play" class="btn-ghost">Play a hand</a>
      <a href="/hands" class="btn-gold">Hand reference</a>
    </div>
  </section>
</PokerLayout>

<script>
  import { getAllHistory } from '../lib/history.js';
  import { getBalance, formatChips, STARTING_BANKROLL } from '../lib/bankroll.js';

  const GAMES = [
    { key: 'holdem', label: "Texas Hold'em" },
    { key: 'blackjack', label: 'Blackjack' },
    { key: 'five-card-draw', label: 'Five-Card Draw' },
    { key: 'video-poker', label: 'Video Poker' },
  ];

  function escapeHtml(s) {
    return String(s ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function isWin(r)  { return r === 'win' || r === 'blackjack'; }
  function isLoss(r) { return r === 'lose'; }
  function isPush(r) { return r === 'push'; }

  function statsFor(entries) {
    const hands = entries.length;
    let net = 0, wins = 0, losses = 0, pushes = 0;
    let biggestWin = 0, biggestLoss = 0;
    for (const e of entries) {
      const d = Number(e.delta) || 0;
      net += d;
      if (isWin(e.result)) wins++;
      else if (isLoss(e.result)) losses++;
      else if (isPush(e.result)) pushes++;
      if (d > biggestWin) biggestWin = d;
      if (d < biggestLoss) biggestLoss = d;
    }
    const decided = wins + losses;
    const winRate = decided > 0 ? (wins / decided) * 100 : null;
    return { hands, net, wins, losses, pushes, biggestWin, biggestLoss, winRate };
  }

  function fmtSigned(n) {
    if (n === 0) return '$0';
    const sign = n > 0 ? '+' : '−';
    return sign + formatChips(Math.abs(n));
  }

  function fmtTimeAgo(t) {
    const s = Math.max(0, Math.floor((Date.now() - t) / 1000));
    if (s < 60) return s + 's ago';
    const m = Math.floor(s / 60);
    if (m < 60) return m + 'm ago';
    const h = Math.floor(m / 60);
    if (h < 24) return h + 'h ago';
    const d = Math.floor(h / 24);
    return d + 'd ago';
  }

  function buildChart(entries) {
    const svgNS = 'http://www.w3.org/2000/svg';
    const chart = document.getElementById('chart');
    const g = document.getElementById('chart-content');
    if (!chart || !g) return;
    g.innerHTML = '';

    const W = 700, H = 200;
    const padL = 56, padR = 16, padT = 16, padB = 28;
    const innerW = W - padL - padR;
    const innerH = H - padT - padB;

    // Sort ascending by time
    const sorted = entries.slice().sort((a, b) => (a.t || 0) - (b.t || 0));

    // Cumulative bankroll points (index 0 = starting bankroll, before any hand)
    const points = [STARTING_BANKROLL];
    let bal = STARTING_BANKROLL;
    for (const e of sorted) {
      bal = Math.max(0, bal + (Number(e.delta) || 0));
      points.push(bal);
    }

    const minV = Math.min(...points);
    const maxV = Math.max(...points);
    const span = maxV - minV || 1;
    const lastIdx = points.length - 1;

    const xAt = (i) => padL + (lastIdx > 0 ? (i / lastIdx) * innerW : innerW / 2);
    const yAt = (v) => padT + innerH - ((v - minV) / span) * innerH;

    // Grid lines: 4 horizontal
    const ticks = 4;
    for (let i = 0; i <= ticks; i++) {
      const v = minV + (span * i) / ticks;
      const y = yAt(v);
      const line = document.createElementNS(svgNS, 'line');
      line.setAttribute('x1', String(padL));
      line.setAttribute('x2', String(W - padR));
      line.setAttribute('y1', y.toFixed(1));
      line.setAttribute('y2', y.toFixed(1));
      line.setAttribute('stroke', '#a89e7a');
      line.setAttribute('stroke-opacity', '0.15');
      line.setAttribute('stroke-width', '1');
      g.appendChild(line);

      const label = document.createElementNS(svgNS, 'text');
      label.setAttribute('x', String(padL - 8));
      label.setAttribute('y', (y + 4).toFixed(1));
      label.setAttribute('text-anchor', 'end');
      label.setAttribute('font-family', 'JetBrains Mono, monospace');
      label.setAttribute('font-size', '10');
      label.setAttribute('fill', '#a89e7a');
      label.textContent = formatChips(Math.round(v));
      g.appendChild(label);
    }

    // Starting bankroll reference line (if within range)
    if (STARTING_BANKROLL >= minV && STARTING_BANKROLL <= maxV) {
      const y0 = yAt(STARTING_BANKROLL);
      const ref = document.createElementNS(svgNS, 'line');
      ref.setAttribute('x1', String(padL));
      ref.setAttribute('x2', String(W - padR));
      ref.setAttribute('y1', y0.toFixed(1));
      ref.setAttribute('y2', y0.toFixed(1));
      ref.setAttribute('stroke', '#a89e7a');
      ref.setAttribute('stroke-opacity', '0.4');
      ref.setAttribute('stroke-dasharray', '2 3');
      g.appendChild(ref);
    }

    if (sorted.length === 0) {
      // Flat dashed line at starting value
      const y0 = yAt(STARTING_BANKROLL);
      const flat = document.createElementNS(svgNS, 'line');
      flat.setAttribute('x1', String(padL));
      flat.setAttribute('x2', String(W - padR));
      flat.setAttribute('y1', y0.toFixed(1));
      flat.setAttribute('y2', y0.toFixed(1));
      flat.setAttribute('stroke', '#d4af37');
      flat.setAttribute('stroke-width', '2');
      flat.setAttribute('stroke-dasharray', '5 5');
      flat.setAttribute('stroke-opacity', '0.7');
      g.appendChild(flat);

      const cap = document.createElementNS(svgNS, 'text');
      cap.setAttribute('x', String(padL + innerW / 2));
      cap.setAttribute('y', String(padT + innerH / 2 + 4));
      cap.setAttribute('text-anchor', 'middle');
      cap.setAttribute('font-family', 'JetBrains Mono, monospace');
      cap.setAttribute('font-size', '11');
      cap.setAttribute('fill', '#a89e7a');
      cap.textContent = 'No hands yet.';
      g.appendChild(cap);
      return;
    }

    // Area path
    const baseY = padT + innerH;
    let areaD = `M ${xAt(0).toFixed(1)},${baseY.toFixed(1)}`;
    for (let i = 0; i < points.length; i++) {
      areaD += ` L ${xAt(i).toFixed(1)},${yAt(points[i]).toFixed(1)}`;
    }
    areaD += ` L ${xAt(lastIdx).toFixed(1)},${baseY.toFixed(1)} Z`;
    const area = document.createElementNS(svgNS, 'path');
    area.setAttribute('d', areaD);
    area.setAttribute('fill', 'url(#brArea)');
    g.appendChild(area);

    // Line
    const linePts = points.map((v, i) => `${xAt(i).toFixed(1)},${yAt(v).toFixed(1)}`).join(' ');
    const line = document.createElementNS(svgNS, 'polyline');
    line.setAttribute('points', linePts);
    line.setAttribute('fill', 'none');
    line.setAttribute('stroke', '#d4af37');
    line.setAttribute('stroke-width', '2');
    line.setAttribute('stroke-linejoin', 'round');
    line.setAttribute('stroke-linecap', 'round');
    g.appendChild(line);

    // End dot
    const endDot = document.createElementNS(svgNS, 'circle');
    endDot.setAttribute('cx', xAt(lastIdx).toFixed(1));
    endDot.setAttribute('cy', yAt(points[lastIdx]).toFixed(1));
    endDot.setAttribute('r', '4');
    endDot.setAttribute('fill', '#f0c855');
    endDot.setAttribute('stroke', '#0d3b2e');
    endDot.setAttribute('stroke-width', '2');
    g.appendChild(endDot);

    // X labels: hand 0 and hand N
    document.getElementById('chart-x-start').textContent = '0';
    document.getElementById('chart-x-end').textContent = String(sorted.length);
    document.getElementById('chart-caption').textContent =
      `Min ${formatChips(minV)} · Max ${formatChips(maxV)}`;
  }

  function renderPerGame(all) {
    const tbody = document.getElementById('per-game-rows');
    if (!tbody) return;

    const rows = GAMES.map((g) => {
      const entries = Array.isArray(all[g.key]) ? all[g.key] : [];
      const s = statsFor(entries);
      if (s.hands === 0) {
        return `
          <tr class="border-b border-gold-deep/10">
            <td class="py-3 pr-3 text-parchment-soft">${escapeHtml(g.label)}</td>
            <td class="py-3 px-2 text-right mono text-parchment-dim">&mdash;</td>
            <td class="py-3 px-2 text-right mono text-parchment-dim">&mdash;</td>
            <td class="py-3 px-2 text-right mono text-parchment-dim">&mdash;</td>
            <td class="py-3 px-2 text-right mono text-parchment-dim">&mdash;</td>
            <td class="py-3 pl-2 text-right mono text-parchment-dim">&mdash;</td>
          </tr>`;
      }
      const netClass = s.net > 0 ? 'win' : s.net < 0 ? 'loss' : 'text-parchment-soft';
      const winRateStr = s.winRate == null ? '&mdash;' : s.winRate.toFixed(0) + '%';
      const bigWin = s.biggestWin > 0 ? '+' + formatChips(s.biggestWin) : '&mdash;';
      const bigLoss = s.biggestLoss < 0 ? '−' + formatChips(Math.abs(s.biggestLoss)) : '&mdash;';
      return `
        <tr class="border-b border-gold-deep/10">
          <td class="py-3 pr-3 text-parchment">${escapeHtml(g.label)}</td>
          <td class="py-3 px-2 text-right mono numeral text-parchment">${s.hands}</td>
          <td class="py-3 px-2 text-right mono numeral ${netClass}">${fmtSigned(s.net)}</td>
          <td class="py-3 px-2 text-right mono numeral text-parchment">${winRateStr}</td>
          <td class="py-3 px-2 text-right mono numeral win">${bigWin}</td>
          <td class="py-3 pl-2 text-right mono numeral loss">${bigLoss}</td>
        </tr>`;
    }).join('');

    tbody.innerHTML = rows;
  }

  function renderRecent(allEntries) {
    const strip = document.getElementById('recent-strip');
    if (!strip) return;

    // allEntries is already cross-game, sorted desc by time
    const last = allEntries.slice(0, 10);
    if (last.length === 0) {
      strip.innerHTML = '<p class="text-parchment-dim text-xs mono">No hands yet.</p>';
      return;
    }
    strip.innerHTML = last.map((e) => {
      const color = isWin(e.result) ? '#4ade80'
        : isLoss(e.result) ? '#f87171'
        : isPush(e.result) ? '#f0c855'
        : '#a89e7a';
      const summary = e.summary || e.result || 'hand';
      const delta = Number(e.delta) || 0;
      const deltaStr = delta === 0 ? '±0' : (delta > 0 ? '+' : '−') + formatChips(Math.abs(delta));
      const title = `${summary} · ${deltaStr}`;
      return `<span
        class="inline-block rounded-sm border border-gold-deep/30"
        style="width:20px;height:20px;background:${color};opacity:0.9;cursor:help"
        title="${escapeHtml(title)}"
        aria-label="${escapeHtml(title)}"></span>`;
    }).join('');
  }

  function renderOverall(entries) {
    const s = statsFor(entries);
    const handsEl = document.getElementById('kpi-hands');
    const netEl = document.getElementById('kpi-net');
    const winrateEl = document.getElementById('kpi-winrate');
    const bankrollEl = document.getElementById('kpi-bankroll');
    const peakEl = document.getElementById('kpi-peak');
    const lowEl = document.getElementById('kpi-low');
    const lastEl = document.getElementById('last-hand-time');

    if (handsEl) handsEl.textContent = String(s.hands);

    if (netEl) {
      netEl.textContent = fmtSigned(s.net);
      netEl.classList.remove('win', 'loss', 'text-gold-bright');
      if (s.net > 0) netEl.classList.add('win');
      else if (s.net < 0) netEl.classList.add('loss');
      else netEl.classList.add('text-gold-bright');
    }

    if (winrateEl) {
      winrateEl.textContent = s.winRate == null ? '—' : s.winRate.toFixed(0) + '%';
    }

    if (bankrollEl) {
      bankrollEl.textContent = formatChips(getBalance());
    }

    // Peak / low from trajectory
    const sorted = entries.slice().sort((a, b) => (a.t || 0) - (b.t || 0));
    let bal = STARTING_BANKROLL, peak = STARTING_BANKROLL, low = STARTING_BANKROLL;
    for (const e of sorted) {
      bal = Math.max(0, bal + (Number(e.delta) || 0));
      if (bal > peak) peak = bal;
      if (bal < low) low = bal;
    }
    if (peakEl) peakEl.textContent = formatChips(peak);
    if (lowEl) lowEl.textContent = formatChips(low);

    // Last hand time — entries sorted desc already in `entries`
    if (lastEl) {
      if (entries.length === 0) lastEl.textContent = '—';
      else lastEl.textContent = fmtTimeAgo(entries[0].t || Date.now());
    }
  }

  function render() {
    const all = getAllHistory() || {};
    // Flatten across games, sorted DESC by time (newest first) for "recent" and "last hand"
    const flat = [];
    for (const key of Object.keys(all)) {
      const list = Array.isArray(all[key]) ? all[key] : [];
      for (const e of list) flat.push(e);
    }
    flat.sort((a, b) => (b.t || 0) - (a.t || 0));

    renderOverall(flat);
    buildChart(flat);
    renderPerGame(all);
    renderRecent(flat);
  }

  // Initial render
  render();

  // React to new hand events and bankroll changes
  window.addEventListener('chipshot:history', render);
  window.addEventListener('chipshot:bankroll', render);
  // Cross-tab sync
  window.addEventListener('storage', (e) => {
    if (!e.key || e.key.startsWith('chipshot.')) render();
  });
</script>
