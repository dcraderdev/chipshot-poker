---
import PokerLayout from '../layouts/PokerLayout.astro';

const games = [
  {
    href: '/games/holdem',
    name: "Texas Hold'em",
    tag: '6-MAX · VS BOTS',
    icon: 'holdem',
  },
  {
    href: '/games/blackjack',
    name: 'Blackjack',
    tag: 'SINGLE DECK · VS DEALER',
    icon: 'blackjack',
  },
  {
    href: '/games/five-card-draw',
    name: 'Five-Card Draw',
    tag: 'CLASSIC · 1 DRAW',
    icon: 'draw',
  },
  {
    href: '/games/video-poker',
    name: 'Video Poker',
    tag: 'JACKS OR BETTER',
    icon: 'video',
  },
];
---
<PokerLayout
  title="ChipShot Poker — Play four casino classics"
  description="Play Hold'em, Blackjack, Five-Card Draw, and Video Poker in your browser. $1,000 in play chips, no signup."
  active="home"
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-16 lg:pt-20 pb-16 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow">Four games &middot; No signup &middot; Play chips only</span>
        <h1 class="display mt-5 text-4xl sm:text-5xl lg:text-6xl text-parchment leading-tight">
          Pull up a <span class="text-gold-bright italic">chair</span>.
        </h1>
        <div class="gold-rule my-6 max-w-md"></div>
        <p class="text-parchment-soft text-base sm:text-lg max-w-xl leading-relaxed">
          Hold&apos;em, Blackjack, Five-Card Draw, Video Poker. Stake yourself
          <span class="text-parchment numeral">$1,000</span> in play chips and learn the felt.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/games" class="btn-gold">Enter the Floor</a>
          <a href="/hands" class="btn-ghost">See hand history</a>
        </div>

        <!-- Inline stake strip -->
        <dl class="mt-10 grid grid-cols-3 gap-px panel overflow-hidden max-w-xl">
          <div class="p-4">
            <dt class="stat-label">Your stake</dt>
            <dd class="stat-value text-2xl mt-1">$1,000</dd>
          </div>
          <div class="p-4 border-l border-gold-deep/30">
            <dt class="stat-label">Signup</dt>
            <dd class="stat-value text-2xl mt-1">None</dd>
          </div>
          <div class="p-4 border-l border-gold-deep/30">
            <dt class="stat-label">Real money</dt>
            <dd class="stat-value text-2xl mt-1">$0</dd>
          </div>
        </dl>
      </div>

      <!-- Hero visual: felt table with chip stacks and hole cards -->
      <div class="lg:col-span-5 relative">
        <div class="relative aspect-square max-w-md mx-auto">
          <svg viewBox="0 0 400 400" class="absolute inset-0 w-full h-full" aria-hidden="true">
            <defs>
              <radialGradient id="feltGrad" cx="50%" cy="45%" r="60%">
                <stop offset="0%" stop-color="#1f7a55"/>
                <stop offset="60%" stop-color="#145a3f"/>
                <stop offset="100%" stop-color="#082619"/>
              </radialGradient>
              <linearGradient id="goldRail" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#f0c855"/>
                <stop offset="50%" stop-color="#d4af37"/>
                <stop offset="100%" stop-color="#a3851f"/>
              </linearGradient>
            </defs>
            <ellipse cx="200" cy="210" rx="180" ry="160" fill="url(#feltGrad)" stroke="url(#goldRail)" stroke-width="6"/>
            <ellipse cx="200" cy="210" rx="150" ry="130" fill="none" stroke="#d4af37" stroke-width="0.8" stroke-dasharray="2 4" opacity="0.5"/>
            <text x="200" y="120" text-anchor="middle" font-family="Playfair Display, serif" font-style="italic" font-size="14" fill="#d4af37" opacity="0.8">ChipShot</text>
            <!-- chip stacks -->
            <g transform="translate(80,260)">
              <ellipse cx="0" cy="14" rx="22" ry="6" fill="#0a0a0a"/>
              <ellipse cx="0" cy="10" rx="22" ry="6" fill="#c9302c" stroke="#f0c855" stroke-width="1"/>
              <ellipse cx="0" cy="4" rx="22" ry="6" fill="#2f6b9a" stroke="#f0c855" stroke-width="1"/>
              <ellipse cx="0" cy="-2" rx="22" ry="6" fill="#111" stroke="#f0c855" stroke-width="1"/>
              <ellipse cx="0" cy="-8" rx="22" ry="6" fill="#c9302c" stroke="#f0c855" stroke-width="1"/>
            </g>
            <g transform="translate(320,270)">
              <ellipse cx="0" cy="10" rx="22" ry="6" fill="#0a0a0a"/>
              <ellipse cx="0" cy="6" rx="22" ry="6" fill="#2f6b9a" stroke="#f0c855" stroke-width="1"/>
              <ellipse cx="0" cy="0" rx="22" ry="6" fill="#c9302c" stroke="#f0c855" stroke-width="1"/>
              <ellipse cx="0" cy="-6" rx="22" ry="6" fill="#2f6b9a" stroke="#f0c855" stroke-width="1"/>
            </g>
            <!-- center pot -->
            <g transform="translate(200,210)">
              <ellipse cx="0" cy="4" rx="18" ry="5" fill="#0a0a0a" opacity="0.6"/>
              <ellipse cx="0" cy="0" rx="18" ry="5" fill="#f0c855" stroke="#a3851f" stroke-width="0.8"/>
              <ellipse cx="0" cy="-5" rx="18" ry="5" fill="#f0c855" stroke="#a3851f" stroke-width="0.8"/>
            </g>
          </svg>

          <!-- Hole cards fanned -->
          <div class="absolute inset-0 flex items-end justify-center pb-10">
            <div class="relative">
              <div class="card xl black absolute" style="transform: translate(-46px, 4px) rotate(-12deg);">A&#9824;</div>
              <div class="card xl red relative" style="transform: rotate(6deg);">K&#9829;</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="gold-rule"></div>
  </section>

  <!-- GAMES STRIP -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="flex items-end justify-between mb-6">
      <div>
        <span class="eyebrow">The floor</span>
        <h2 class="display text-2xl sm:text-3xl text-parchment mt-2">Pick your <span class="text-gold-bright italic">game</span>.</h2>
      </div>
      <a href="/games" class="stat-label hidden sm:inline hover:text-gold-bright transition-colors">All games &rarr;</a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {games.map((g) => (
        <a href={g.href} class="cs-game-card group block">
          <div class="cs-game-card__art">
            {g.icon === 'holdem' && (
              <svg viewBox="0 0 80 80" class="w-[60px] h-[60px]" aria-hidden="true">
                <rect x="14" y="20" width="22" height="32" rx="3" fill="#f4ecd4" stroke="#a3851f" stroke-width="1" transform="rotate(-10 25 36)"/>
                <text x="25" y="38" text-anchor="middle" font-family="Playfair Display, serif" font-size="14" fill="#0a0a0a" transform="rotate(-10 25 36)">A</text>
                <text x="25" y="50" text-anchor="middle" font-size="12" fill="#0a0a0a" transform="rotate(-10 25 36)">&#9824;</text>
                <rect x="44" y="20" width="22" height="32" rx="3" fill="#f4ecd4" stroke="#a3851f" stroke-width="1" transform="rotate(10 55 36)"/>
                <text x="55" y="38" text-anchor="middle" font-family="Playfair Display, serif" font-size="14" fill="#c9302c" transform="rotate(10 55 36)">K</text>
                <text x="55" y="50" text-anchor="middle" font-size="12" fill="#c9302c" transform="rotate(10 55 36)">&#9829;</text>
              </svg>
            )}
            {g.icon === 'blackjack' && (
              <svg viewBox="0 0 80 80" class="w-[60px] h-[60px]" aria-hidden="true">
                <rect x="18" y="18" width="22" height="32" rx="3" fill="#f4ecd4" stroke="#a3851f" stroke-width="1" transform="rotate(-8 29 34)"/>
                <text x="29" y="36" text-anchor="middle" font-family="Playfair Display, serif" font-size="13" fill="#0a0a0a" transform="rotate(-8 29 34)">A</text>
                <text x="29" y="48" text-anchor="middle" font-size="11" fill="#0a0a0a" transform="rotate(-8 29 34)">&#9824;</text>
                <rect x="40" y="20" width="22" height="32" rx="3" fill="#f4ecd4" stroke="#a3851f" stroke-width="1" transform="rotate(8 51 36)"/>
                <text x="51" y="38" text-anchor="middle" font-family="Playfair Display, serif" font-size="13" fill="#0a0a0a" transform="rotate(8 51 36)">J</text>
                <text x="51" y="50" text-anchor="middle" font-size="11" fill="#0a0a0a" transform="rotate(8 51 36)">&#9824;</text>
                <text x="40" y="72" text-anchor="middle" font-family="Playfair Display, serif" font-style="italic" font-size="10" fill="#d4af37">21</text>
              </svg>
            )}
            {g.icon === 'draw' && (
              <svg viewBox="0 0 80 80" class="w-[60px] h-[60px]" aria-hidden="true">
                <g transform="translate(40,40)">
                  <rect x="-22" y="-16" width="14" height="20" rx="2" fill="#f4ecd4" stroke="#a3851f" stroke-width="0.8" transform="rotate(-20)"/>
                  <rect x="-14" y="-17" width="14" height="20" rx="2" fill="#f4ecd4" stroke="#a3851f" stroke-width="0.8" transform="rotate(-10)"/>
                  <rect x="-7" y="-18" width="14" height="20" rx="2" fill="#f4ecd4" stroke="#a3851f" stroke-width="0.8"/>
                  <rect x="0" y="-17" width="14" height="20" rx="2" fill="#f4ecd4" stroke="#a3851f" stroke-width="0.8" transform="rotate(10)"/>
                  <rect x="8" y="-16" width="14" height="20" rx="2" fill="#f4ecd4" stroke="#a3851f" stroke-width="0.8" transform="rotate(20)"/>
                </g>
                <text x="40" y="70" text-anchor="middle" font-size="9" fill="#d4af37" font-family="ui-monospace,monospace">5</text>
              </svg>
            )}
            {g.icon === 'video' && (
              <svg viewBox="0 0 80 80" class="w-[60px] h-[60px]" aria-hidden="true">
                <rect x="10" y="18" width="60" height="44" rx="4" fill="#082619" stroke="#d4af37" stroke-width="1.2"/>
                <g transform="translate(15,28)">
                  <rect x="0" y="0" width="9" height="14" rx="1" fill="#f4ecd4"/>
                  <rect x="11" y="0" width="9" height="14" rx="1" fill="#f4ecd4"/>
                  <rect x="22" y="0" width="9" height="14" rx="1" fill="#f4ecd4"/>
                  <rect x="33" y="0" width="9" height="14" rx="1" fill="#f4ecd4"/>
                  <rect x="44" y="0" width="9" height="14" rx="1" fill="#f4ecd4"/>
                </g>
                <text x="40" y="56" text-anchor="middle" font-family="ui-monospace,monospace" font-size="7" fill="#f0c855">JACKS OR BETTER</text>
              </svg>
            )}
          </div>
          <h3 class="display text-lg text-parchment group-hover:text-gold-bright transition-colors mt-3">{g.name}</h3>
          <p class="mono text-xs text-gold-bright mt-1">{g.tag}</p>
        </a>
      ))}
    </div>
  </section>

  <div class="gold-rule max-w-7xl mx-auto"></div>

  <!-- HOW IT WORKS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="mb-6">
      <span class="eyebrow">House rules</span>
      <h2 class="display text-2xl sm:text-3xl text-parchment mt-2">How it <span class="text-gold-bright italic">works</span>.</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <div class="panel p-6">
        <span class="stat-label">01 &middot; Buy-in</span>
        <h3 class="display text-xl text-gold-bright mt-2">Stake yourself</h3>
        <p class="text-parchment-soft text-sm mt-2 leading-relaxed">
          <span class="numeral text-parchment">$1,000</span> in play chips, stored in your browser. No signup, no email, no card.
        </p>
      </div>
      <div class="panel p-6">
        <span class="stat-label">02 &middot; Sit down</span>
        <h3 class="display text-xl text-gold-bright mt-2">Play any game</h3>
        <p class="text-parchment-soft text-sm mt-2 leading-relaxed">
          Hold&apos;em vs bots, Blackjack vs the dealer, Five-Card Draw, Video Poker. Switch tables whenever.
        </p>
      </div>
      <div class="panel p-6">
        <span class="stat-label">03 &middot; Keep score</span>
        <h3 class="display text-xl text-gold-bright mt-2">Track everything</h3>
        <p class="text-parchment-soft text-sm mt-2 leading-relaxed">
          Hands and stats logged automatically. Bust out? Reload the page and you&apos;re back at <span class="numeral text-parchment">$1,000</span>.
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER NOTE -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="gold-rule mb-6"></div>
    <p class="text-center mono text-xs text-parchment-dim">
      Built for fun. No real money. Open source &mdash; see this concept site by
      <a href="https://dcrader.dev" class="text-gold-bright hover:underline">Donovan Crader</a>.
    </p>
  </section>
</PokerLayout>
