---
import PokerLayout from '../layouts/PokerLayout.astro';
---
<PokerLayout
  title="Take a seat — ChipShot Poker"
  description="Pick a name, claim your chips, sit down at a game."
  active="games"
>
  <section class="max-w-2xl mx-auto px-4 py-12 sm:py-20">
    <!-- Returning player panel -->
    <div id="returning" class="onb-step" hidden>
      <span class="eyebrow">Welcome back</span>
      <h1 class="display mt-5 text-3xl sm:text-4xl text-parchment leading-tight">
        Welcome back, <span class="text-gold-bright italic" id="returning-name">friend</span>.
      </h1>
      <div class="gold-rule my-6 max-w-md"></div>
      <p class="text-parchment-soft text-base sm:text-lg leading-relaxed">
        Your seat is still warm and your chips are stacked.
        Jump right back to the lobby, or wipe the slate clean and start over.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/games" class="btn-gold" data-action="continue-lobby">Continue to lobby</a>
        <button type="button" class="btn-ghost" data-action="start-over">Start over</button>
      </div>
    </div>

    <!-- Step 1 — Welcome -->
    <div id="step-1" class="onb-step" hidden>
      <span class="eyebrow">New player</span>
      <h1 class="display mt-5 text-4xl sm:text-5xl text-parchment leading-tight">
        Welcome to <span class="text-gold-bright italic">ChipShot</span> Poker.
      </h1>
      <div class="gold-rule my-6 max-w-md"></div>
      <p class="text-parchment-soft text-base sm:text-lg leading-relaxed">
        A free demo lounge — no money, no signup, no nonsense.
        Claim a stack of chips, take a name, and pull up a seat.
      </p>

      <div class="panel p-5 sm:p-6 mt-8 flex items-center gap-4">
        <div class="flex -space-x-2 shrink-0" aria-hidden="true">
          <span class="chip" style="background: var(--color-chip-red);"></span>
          <span class="chip" style="background: var(--color-chip-blue);"></span>
          <span class="chip" style="background: var(--color-chip-black);"></span>
        </div>
        <div class="text-sm">
          <div class="stat-label">Starting stack</div>
          <div class="numeral text-xl text-gold-bright mt-1">$1,000 in demo chips</div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <button type="button" class="btn-gold" data-action="to-step-2">Get started</button>
        <a href="/" class="btn-ghost">Back to home</a>
      </div>
    </div>

    <!-- Step 2 — Pick a name -->
    <div id="step-2" class="onb-step" hidden>
      <span class="eyebrow">Step 2 of 3 &middot; Your handle</span>
      <h2 class="display mt-5 text-3xl sm:text-4xl text-parchment leading-tight">
        What should we call you at the <span class="text-gold-bright italic">table</span>?
      </h2>
      <div class="gold-rule my-6 max-w-md"></div>
      <p class="text-parchment-soft text-base leading-relaxed">
        Three to twenty characters. You can change this later — or leave it as
        <span class="mono text-parchment">Anonymous Jack</span> and stay mysterious.
      </p>

      <form id="name-form" class="mt-8 panel p-5 sm:p-6 space-y-5" novalidate>
        <div>
          <label for="username" class="stat-label block mb-2">Table name</label>
          <input
            id="username"
            name="username"
            type="text"
            autocomplete="off"
            spellcheck="false"
            inputmode="text"
            minlength="3"
            maxlength="20"
            required
            placeholder="Anonymous Jack"
            aria-describedby="username-help username-error"
            class="w-full px-4 py-3 mono text-base text-parchment bg-felt-deep border border-gold-deep/40 rounded-sm focus:border-gold-bright focus:outline-none"
          />
          <p id="username-help" class="stat-label mt-2">3–20 characters</p>
          <p id="username-error" class="mono text-xs mt-2 loss" hidden></p>
        </div>

        <div>
          <p class="stat-label mb-2">Or borrow one of these</p>
          <div class="flex flex-wrap gap-2" role="group" aria-label="Suggested names">
            <button type="button" class="suggest-chip" data-name="River Rat">River Rat</button>
            <button type="button" class="suggest-chip" data-name="Tilt Master">Tilt Master</button>
            <button type="button" class="suggest-chip" data-name="The Calling Station">The Calling Station</button>
            <button type="button" class="suggest-chip" data-name="Set Mining Sue">Set Mining Sue</button>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 pt-1">
          <button id="continue-btn" type="submit" class="btn-gold" disabled>Continue</button>
          <button type="button" class="btn-ghost" data-action="to-step-1">Back</button>
        </div>
      </form>
    </div>

    <!-- Step 3 — Claim chips -->
    <div id="step-3" class="onb-step" hidden>
      <span class="eyebrow">Step 3 of 3 &middot; Claim your chips</span>
      <h2 class="display mt-5 text-3xl sm:text-4xl text-parchment leading-tight">
        You'll start with <span class="text-gold-bright italic">$1,000</span> in demo chips.
      </h2>
      <div class="gold-rule my-6 max-w-md"></div>
      <p class="text-parchment-soft text-base leading-relaxed">
        Play freely. Lose it all? Reset and start again — your seat at
        <span class="mono text-parchment" id="confirm-name">the table</span> is always open.
      </p>

      <!-- Animated chip stack -->
      <div class="mt-8 panel p-6 sm:p-10 flex items-center justify-center" aria-hidden="true">
        <svg viewBox="0 0 240 200" class="w-full max-w-xs h-auto" id="chip-stack-svg">
          <defs>
            <radialGradient id="onbFelt" cx="50%" cy="50%" r="60%">
              <stop offset="0%" stop-color="#1f7a55"/>
              <stop offset="80%" stop-color="#082619"/>
            </radialGradient>
            <linearGradient id="onbGold" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#f0c855"/>
              <stop offset="100%" stop-color="#a3851f"/>
            </linearGradient>
          </defs>
          <ellipse cx="120" cy="160" rx="100" ry="22" fill="url(#onbFelt)" opacity="0.7"/>
          <!-- Stack (built upward — animation delays cascade) -->
          <g class="chip-row" style="--i:0">
            <ellipse cx="120" cy="158" rx="56" ry="12" fill="#0a0a0a"/>
            <ellipse cx="120" cy="152" rx="56" ry="12" fill="#c9302c" stroke="url(#onbGold)" stroke-width="1.2"/>
          </g>
          <g class="chip-row" style="--i:1">
            <ellipse cx="120" cy="140" rx="56" ry="12" fill="#2f6b9a" stroke="url(#onbGold)" stroke-width="1.2"/>
          </g>
          <g class="chip-row" style="--i:2">
            <ellipse cx="120" cy="128" rx="56" ry="12" fill="#111" stroke="url(#onbGold)" stroke-width="1.2"/>
          </g>
          <g class="chip-row" style="--i:3">
            <ellipse cx="120" cy="116" rx="56" ry="12" fill="#c9302c" stroke="url(#onbGold)" stroke-width="1.2"/>
          </g>
          <g class="chip-row" style="--i:4">
            <ellipse cx="120" cy="104" rx="56" ry="12" fill="#2f6b9a" stroke="url(#onbGold)" stroke-width="1.2"/>
          </g>
          <g class="chip-row" style="--i:5">
            <ellipse cx="120" cy="92" rx="56" ry="12" fill="#f0c855" stroke="#a3851f" stroke-width="1.2"/>
            <text x="120" y="96" text-anchor="middle" font-family="Playfair Display, serif"
              font-style="italic" font-size="14" fill="#082619" font-weight="700">$1,000</text>
          </g>
        </svg>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <button type="button" class="btn-gold" data-action="claim">Take a seat</button>
        <button type="button" class="btn-ghost" data-action="to-step-2">Back</button>
      </div>
    </div>

    <!-- Step pip indicator -->
    <div id="step-pips" class="mt-10 flex items-center gap-2 mono text-xs text-parchment-dim" hidden>
      <span data-pip="1" class="pip"></span>
      <span data-pip="2" class="pip"></span>
      <span data-pip="3" class="pip"></span>
    </div>
  </section>

  <style>
    .onb-step {
      animation: onb-in 220ms ease-out both;
    }
    @keyframes onb-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .suggest-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.75rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      color: var(--color-parchment);
      background: rgba(8, 38, 25, 0.55);
      border: 1px solid rgba(212, 175, 55, 0.3);
      border-radius: 999px;
      cursor: pointer;
      transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
    }
    .suggest-chip:hover {
      color: var(--color-gold-bright);
      border-color: var(--color-gold);
      background: rgba(20, 90, 63, 0.55);
    }

    #username {
      background: rgba(8, 38, 25, 0.55);
    }
    #username::placeholder { color: var(--color-parchment-dim); }

    .pip {
      width: 18px;
      height: 2px;
      background: var(--color-parchment-dim);
      opacity: 0.4;
      transition: opacity 0.2s ease, background 0.2s ease;
    }
    .pip.is-active { background: var(--color-gold-bright); opacity: 1; }
    .pip.is-done   { background: var(--color-gold); opacity: 0.8; }

    .chip-row {
      transform-origin: 120px 160px;
      animation: chip-drop 360ms cubic-bezier(.2,.7,.3,1.2) both;
      animation-delay: calc(var(--i, 0) * 90ms);
    }
    @keyframes chip-drop {
      0%   { transform: translateY(-40px); opacity: 0; }
      70%  { transform: translateY(3px);   opacity: 1; }
      100% { transform: translateY(0);     opacity: 1; }
    }

    @media (prefers-reduced-motion: reduce) {
      .onb-step, .chip-row { animation: none; }
    }

    button[disabled].btn-gold {
      opacity: 0.45;
      cursor: not-allowed;
      filter: grayscale(0.25);
    }
    button[disabled].btn-gold:hover {
      transform: none;
      filter: grayscale(0.25);
    }
  </style>

  <script>
    import { getProfile, setProfile, resetBankroll } from '../lib/bankroll.js';

    const DEFAULT_NAME = 'Anonymous Jack';

    const stepIds = ['returning', 'step-1', 'step-2', 'step-3'];
    const steps = Object.fromEntries(
      stepIds.map((id) => [id, document.getElementById(id)])
    );
    const pipsWrap = document.getElementById('step-pips');
    const pips = pipsWrap ? Array.from(pipsWrap.querySelectorAll('.pip')) : [];

    const usernameInput = /** @type {HTMLInputElement|null} */ (document.getElementById('username'));
    const continueBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById('continue-btn'));
    const nameForm = /** @type {HTMLFormElement|null} */ (document.getElementById('name-form'));
    const errorEl = document.getElementById('username-error');
    const confirmName = document.getElementById('confirm-name');
    const returningName = document.getElementById('returning-name');

    function show(id) {
      stepIds.forEach((k) => {
        const el = steps[k];
        if (!el) return;
        const visible = k === id;
        el.hidden = !visible;
        if (visible) {
          // restart animation
          el.style.animation = 'none';
          // force reflow
          void el.offsetWidth;
          el.style.animation = '';
        }
      });

      const showPips = id === 'step-1' || id === 'step-2' || id === 'step-3';
      if (pipsWrap) pipsWrap.hidden = !showPips;
      const stepIdx = id === 'step-1' ? 0 : id === 'step-2' ? 1 : id === 'step-3' ? 2 : -1;
      pips.forEach((p, i) => {
        p.classList.toggle('is-active', i === stepIdx);
        p.classList.toggle('is-done', i < stepIdx);
      });

      // Focus management
      requestAnimationFrame(() => {
        if (id === 'step-2' && usernameInput) {
          usernameInput.focus();
          if (!usernameInput.value) usernameInput.value = '';
        } else {
          const target = steps[id]?.querySelector('h1, h2');
          if (target instanceof HTMLElement) {
            target.setAttribute('tabindex', '-1');
            target.focus({ preventScroll: true });
          }
        }
      });
    }

    function sanitizeName(raw) {
      return (raw || '').replace(/\s+/g, ' ').trim();
    }

    function validateName(raw) {
      const name = sanitizeName(raw);
      if (name.length === 0) return { ok: true, name: DEFAULT_NAME };
      if (name.length < 3) return { ok: false, error: 'At least 3 characters.' };
      if (name.length > 20) return { ok: false, error: 'No more than 20 characters.' };
      return { ok: true, name };
    }

    function refreshContinueState() {
      if (!usernameInput || !continueBtn) return;
      const raw = usernameInput.value;
      const { ok, error } = validateName(raw);
      // Empty = valid (defaults to Anonymous Jack)
      const empty = sanitizeName(raw).length === 0;
      continueBtn.disabled = !ok;
      if (errorEl) {
        if (!ok && !empty) {
          errorEl.textContent = error || '';
          errorEl.hidden = false;
        } else {
          errorEl.textContent = '';
          errorEl.hidden = true;
        }
      }
    }

    // Step navigation via [data-action]
    document.querySelectorAll('[data-action]').forEach((el) => {
      el.addEventListener('click', (e) => {
        const action = /** @type {HTMLElement} */ (e.currentTarget).dataset.action;
        if (action === 'to-step-1') { show('step-1'); }
        else if (action === 'to-step-2') { show('step-2'); }
        else if (action === 'claim') {
          const raw = usernameInput?.value || '';
          const { ok, name } = validateName(raw);
          if (!ok) { show('step-2'); return; }
          const finalName = name || DEFAULT_NAME;
          try {
            resetBankroll();
            setProfile({ username: finalName, onboarded: true });
          } catch {}
          window.location.href = '/games';
        }
        else if (action === 'continue-lobby') {
          // Anchor handles nav, but keep explicit for completeness.
        }
        else if (action === 'start-over') {
          try {
            setProfile({ username: null, onboarded: false });
            resetBankroll();
          } catch {}
          if (usernameInput) usernameInput.value = '';
          refreshContinueState();
          show('step-1');
        }
      });
    });

    // Suggestion chips
    document.querySelectorAll('.suggest-chip').forEach((el) => {
      el.addEventListener('click', () => {
        const name = /** @type {HTMLElement} */ (el).dataset.name || '';
        if (!usernameInput) return;
        usernameInput.value = name;
        usernameInput.focus();
        refreshContinueState();
      });
    });

    // Input live validation
    if (usernameInput) {
      usernameInput.addEventListener('input', refreshContinueState);
    }

    // Form submit → step 3
    if (nameForm) {
      nameForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const raw = usernameInput?.value || '';
        const { ok, name } = validateName(raw);
        if (!ok) { refreshContinueState(); usernameInput?.focus(); return; }
        const finalName = name || DEFAULT_NAME;
        if (confirmName) confirmName.textContent = finalName;
        // Replay chip-drop animation
        const svg = document.getElementById('chip-stack-svg');
        if (svg) {
          svg.querySelectorAll('.chip-row').forEach((g) => {
            const el = /** @type {SVGGElement} */ (g);
            el.style.animation = 'none';
            void el.getBoundingClientRect();
            el.style.animation = '';
          });
        }
        show('step-3');
      });
    }

    // Initial routing — runs after DOM ready; safe to call browser APIs here.
    function init() {
      const profile = getProfile();
      if (profile.onboarded && profile.username) {
        if (returningName) returningName.textContent = profile.username;
        show('returning');
      } else {
        show('step-1');
      }
      // Pre-fill input with existing username if any
      if (usernameInput && profile.username) {
        usernameInput.value = profile.username;
      }
      refreshContinueState();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  </script>
</PokerLayout>
