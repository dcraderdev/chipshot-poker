---
import PokerLayout from '../layouts/PokerLayout.astro';

const games = [
  {
    eyebrow: 'No-Limit Hold’em',
    name: 'Texas Hold’em',
    rules:
      'Each player gets two hole cards. Five community cards come out across the flop, turn, and river. Best five-card poker hand wins the pot. We deal $5/$10 blinds vs three bots.',
    terms: ['hole cards', 'community board', 'blinds', 'pot', 'showdown'],
    href: '/games/holdem',
    cta: 'Play Hold’em',
  },
  {
    eyebrow: 'House Game',
    name: 'Blackjack',
    rules:
      'Get closer to 21 than the dealer without busting. Aces count 1 or 11; face cards count 10. Hit, stand, double, or split. Blackjack pays 3:2; dealer hits soft 17.',
    terms: ['hit', 'stand', 'double', 'split', 'soft 17'],
    href: '/games/blackjack',
    cta: 'Play Blackjack',
  },
  {
    eyebrow: 'Classic Draw',
    name: 'Five-Card Draw',
    rules:
      'Each player antes, gets five cards, and may discard any number for replacements. One round of betting, then showdown. Pure poker — no community cards.',
    terms: ['ante', 'draw', 'discard', 'betting round', 'showdown'],
    href: '/games/five-card-draw',
    cta: 'Play Five-Card Draw',
  },
  {
    eyebrow: '9/6 Jacks or Better',
    name: 'Video Poker',
    rules:
      'Bet 1–5 coins, get five cards, hold any number, draw replacements. Hands of a pair of jacks or better pay. Royal Flush at max bet pays 4,000.',
    terms: ['coins', 'hold', 'draw', 'paytable', 'royal flush'],
    href: '/games/video-poker',
    cta: 'Play Video Poker',
  },
];
---
<PokerLayout
  title="How to Play — ChipShot Poker"
  description="Quick rules for Texas Hold’em, Blackjack, Five-Card Draw, and Video Poker."
  active="play"
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14">
    <span class="eyebrow">Rules</span>
    <h1 class="display text-3xl sm:text-4xl text-parchment mt-3">How to Play</h1>
    <p class="text-parchment-soft text-sm mt-2 max-w-2xl">
      Quick rundown for each of the four games on the floor.
    </p>
    <div class="gold-rule mt-6"></div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="sm:grid sm:grid-cols-2 sm:gap-6 space-y-6 sm:space-y-0">
      {games.map((g) => (
        <article class="panel p-5 sm:p-6 flex flex-col">
          <span class="eyebrow">{g.eyebrow}</span>
          <h2 class="display text-2xl text-parchment mt-2">{g.name}</h2>

          <p class="text-parchment-soft text-sm mt-3 leading-relaxed">
            {g.rules}
          </p>

          <div class="mt-5">
            <p class="stat-label">Key terms</p>
            <div class="flex flex-wrap gap-2 mt-2">
              {g.terms.map((t) => (
                <span class="mono text-xs px-2.5 py-1 border border-gold-deep/50 rounded-sm text-parchment-soft">
                  {t}
                </span>
              ))}
            </div>
          </div>

          <div class="gold-rule mt-6"></div>

          <div class="mt-5 flex">
            <a href={g.href} class="btn-gold">{g.cta} &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 text-center">
    <div class="gold-rule mb-6"></div>
    <p class="display text-2xl text-parchment">Ready to sit down?</p>
    <p class="text-parchment-soft text-sm mt-2">Pick a table from the lobby — chips are on the house.</p>
    <div class="mt-5 flex justify-center gap-3 flex-wrap">
      <a href="/games" class="btn-gold">Open the lobby &rarr;</a>
    </div>
  </section>
</PokerLayout>
