---
import PokerLayout from '../../layouts/PokerLayout.astro';

const games = [
  { slug: 'holdem',         name: "Texas Hold'em",   tag: 'Live · 4 players',     blurb: "$5/$10 NLHE. You vs three bots, deal as many hands as you like." },
  { slug: 'blackjack',      name: 'Blackjack',       tag: 'Vs Dealer · 3:2',      blurb: 'Single-deck, dealer hits soft 17. Double and split enabled.' },
  { slug: 'five-card-draw', name: 'Five-Card Draw',  tag: 'Heads-up · $10 ante',  blurb: 'Old-school draw poker, one draw + one bet round. Classic.' },
  { slug: 'video-poker',    name: 'Video Poker',     tag: '9/6 Jacks or Better',  blurb: 'Hold and draw. Bet 1–5 coins. Royal Flush pays 4,000.' },
];
---
<PokerLayout
  title="Play — ChipShot Poker"
  description="Choose a game: Hold'em, Blackjack, Five-Card Draw, or Video Poker."
  active="games"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid lg:grid-cols-[1fr_auto] gap-6 items-start">
      <div>
        <span class="eyebrow">Lobby</span>
        <h1 class="display text-4xl sm:text-5xl text-parchment mt-3">The Floor</h1>
        <p class="text-parchment-soft text-sm mt-3 max-w-xl leading-relaxed">
          Four tables, no waitlist. Pull up a chair at any felt &mdash; your bankroll travels with you.
          Every hand lands in your journal automatically.
        </p>
      </div>

      <aside class="panel p-5 w-full lg:w-72" aria-label="Bankroll">
        <div class="flex items-center justify-between">
          <span class="stat-label">Bankroll</span>
          <span class="mono text-xs text-parchment-dim" id="lobby-user-line"></span>
        </div>
        <p class="display text-4xl text-gold-bright mt-2 mono" id="lobby-balance">$1,000</p>
        <div class="gold-rule my-4"></div>
        <button
          type="button"
          id="lobby-reset"
          class="btn-ghost w-full"
          aria-label="Reset bankroll to one thousand dollars"
        >
          Reset to $1,000
        </button>
        <p class="mono text-[0.65rem] text-parchment-dim mt-3 text-center tracking-widest">
          PLAY MONEY · NO REAL WAGERS
        </p>
      </aside>
    </div>

    <div class="gold-rule mt-8"></div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-10" aria-label="Games">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {games.map(({ slug, name, tag, blurb }) => (
        <a href={`/games/${slug}`} class="cs-game-card">
          <div class="cs-game-card__art" aria-hidden="true">
            {slug === 'holdem' && (
              <svg viewBox="0 0 120 130" width="120" height="130" role="img" aria-label="Texas Hold'em fanned cards over felt">
                <defs>
                  <radialGradient id="holdem-felt" cx="50%" cy="60%" r="60%">
                    <stop offset="0%" stop-color="#1f7a55" />
                    <stop offset="60%" stop-color="#0d3b2e" />
                    <stop offset="100%" stop-color="#062018" />
                  </radialGradient>
                </defs>
                <ellipse cx="60" cy="95" rx="55" ry="22" fill="url(#holdem-felt)" stroke="#a3851f" stroke-width="1.5"/>
                <ellipse cx="60" cy="93" rx="40" ry="12" fill="none" stroke="#d4af37" stroke-width="0.5" stroke-dasharray="2 3" opacity="0.5"/>
                {/* fanned cards */}
                <g transform="translate(60 60)">
                  <g transform="rotate(-22) translate(-12 -36)">
                    <rect width="28" height="40" rx="3" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="5" y="13" font-family="Playfair Display, serif" font-weight="700" font-size="11" fill="#0c0c0c">K</text>
                    <text x="5" y="24" font-size="10" fill="#0c0c0c">♣</text>
                  </g>
                  <g transform="rotate(-7) translate(-14 -38)">
                    <rect width="28" height="40" rx="3" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="5" y="13" font-family="Playfair Display, serif" font-weight="700" font-size="11" fill="#d9404a">A</text>
                    <text x="5" y="24" font-size="10" fill="#d9404a">♥</text>
                  </g>
                  <g transform="rotate(9) translate(-14 -38)">
                    <rect width="28" height="40" rx="3" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="5" y="13" font-family="Playfair Display, serif" font-weight="700" font-size="11" fill="#0c0c0c">Q</text>
                    <text x="5" y="24" font-size="10" fill="#0c0c0c">♠</text>
                  </g>
                  <g transform="rotate(24) translate(-14 -36)">
                    <rect width="28" height="40" rx="3" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="5" y="13" font-family="Playfair Display, serif" font-weight="700" font-size="11" fill="#d9404a">J</text>
                    <text x="5" y="24" font-size="10" fill="#d9404a">♦</text>
                  </g>
                </g>
                {/* chip stack */}
                <g transform="translate(95 102)">
                  <ellipse cx="0" cy="6" rx="10" ry="3" fill="#082619" opacity="0.6"/>
                  <ellipse cx="0" cy="2" rx="9" ry="2.5" fill="#c9302c" stroke="#d4af37" stroke-width="0.5"/>
                  <ellipse cx="0" cy="-1" rx="9" ry="2.5" fill="#111111" stroke="#d4af37" stroke-width="0.5"/>
                  <ellipse cx="0" cy="-4" rx="9" ry="2.5" fill="#2f6b9a" stroke="#d4af37" stroke-width="0.5"/>
                </g>
              </svg>
            )}

            {slug === 'blackjack' && (
              <svg viewBox="0 0 120 130" width="120" height="130" role="img" aria-label="Blackjack twenty-one with spade">
                <defs>
                  <radialGradient id="bj-felt" cx="50%" cy="60%" r="60%">
                    <stop offset="0%" stop-color="#1f7a55" />
                    <stop offset="60%" stop-color="#0d3b2e" />
                    <stop offset="100%" stop-color="#062018" />
                  </radialGradient>
                </defs>
                <ellipse cx="60" cy="100" rx="55" ry="20" fill="url(#bj-felt)" stroke="#a3851f" stroke-width="1.5"/>
                <text x="60" y="92" text-anchor="middle" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#f0c855" letter-spacing="2">BLACKJACK</text>
                {/* big 21 */}
                <g transform="translate(60 50)">
                  <text x="0" y="0" text-anchor="middle" font-family="Playfair Display, serif" font-weight="800" font-size="48" fill="#f0c855" stroke="#a3851f" stroke-width="1">21</text>
                </g>
                {/* spade */}
                <g transform="translate(60 65)">
                  <text x="0" y="0" text-anchor="middle" font-size="22" fill="#0c0c0c" stroke="#d4af37" stroke-width="0.5">♠</text>
                </g>
                {/* mini cards corners */}
                <g transform="translate(14 24) rotate(-12)">
                  <rect width="22" height="32" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                  <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#0c0c0c">A</text>
                  <text x="3" y="21" font-size="8" fill="#0c0c0c">♠</text>
                </g>
                <g transform="translate(82 22) rotate(15)">
                  <rect width="22" height="32" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                  <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="8" fill="#0c0c0c">10</text>
                  <text x="3" y="21" font-size="8" fill="#d9404a">♥</text>
                </g>
              </svg>
            )}

            {slug === 'five-card-draw' && (
              <svg viewBox="0 0 120 130" width="120" height="130" role="img" aria-label="Five-card draw fan">
                <defs>
                  <radialGradient id="draw-felt" cx="50%" cy="60%" r="60%">
                    <stop offset="0%" stop-color="#1f7a55" />
                    <stop offset="60%" stop-color="#0d3b2e" />
                    <stop offset="100%" stop-color="#062018" />
                  </radialGradient>
                </defs>
                <ellipse cx="60" cy="100" rx="55" ry="20" fill="url(#draw-felt)" stroke="#a3851f" stroke-width="1.5"/>
                {/* 5-card fan */}
                <g transform="translate(60 75)">
                  <g transform="rotate(-32) translate(-12 -42)">
                    <rect width="24" height="36" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#d9404a">9</text>
                    <text x="3" y="21" font-size="8" fill="#d9404a">♥</text>
                  </g>
                  <g transform="rotate(-16) translate(-12 -46)">
                    <rect width="24" height="36" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#0c0c0c">10</text>
                    <text x="3" y="21" font-size="8" fill="#0c0c0c">♠</text>
                  </g>
                  <g transform="translate(-12 -50)">
                    <rect width="24" height="36" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#0c0c0c">J</text>
                    <text x="3" y="21" font-size="8" fill="#0c0c0c">♣</text>
                  </g>
                  <g transform="rotate(16) translate(-12 -46)">
                    <rect width="24" height="36" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#d9404a">Q</text>
                    <text x="3" y="21" font-size="8" fill="#d9404a">♦</text>
                  </g>
                  <g transform="rotate(32) translate(-12 -42)">
                    <rect width="24" height="36" rx="2.5" fill="#faf3df" stroke="#0c0c0c" stroke-width="0.5"/>
                    <text x="3" y="11" font-family="Playfair Display, serif" font-weight="700" font-size="9" fill="#0c0c0c">K</text>
                    <text x="3" y="21" font-size="8" fill="#0c0c0c">♠</text>
                  </g>
                </g>
                <text x="60" y="125" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="600" font-size="7" fill="#d9cda6" letter-spacing="2">STRAIGHT</text>
              </svg>
            )}

            {slug === 'video-poker' && (
              <svg viewBox="0 0 120 130" width="120" height="130" role="img" aria-label="Video poker arcade screen">
                {/* cabinet */}
                <rect x="14" y="14" width="92" height="100" rx="6" fill="#0d3b2e" stroke="#a3851f" stroke-width="2"/>
                <rect x="14" y="14" width="92" height="100" rx="6" fill="none" stroke="#d4af37" stroke-width="0.5" stroke-dasharray="2 2" transform="translate(2 2)" opacity="0.3"/>
                {/* screen */}
                <rect x="20" y="20" width="80" height="48" rx="2" fill="#062018" stroke="#f0c855" stroke-width="0.8"/>
                {/* 5 mini cards in screen */}
                <g transform="translate(23 26)">
                  <rect width="13" height="20" rx="1.5" fill="#faf3df"/>
                  <text x="2" y="7" font-family="Playfair Display, serif" font-weight="700" font-size="6" fill="#0c0c0c">J</text>
                  <text x="2" y="14" font-size="5" fill="#0c0c0c">♠</text>
                </g>
                <g transform="translate(38 26)">
                  <rect width="13" height="20" rx="1.5" fill="#faf3df"/>
                  <text x="2" y="7" font-family="Playfair Display, serif" font-weight="700" font-size="6" fill="#d9404a">J</text>
                  <text x="2" y="14" font-size="5" fill="#d9404a">♥</text>
                </g>
                <g transform="translate(53 26)">
                  <rect width="13" height="20" rx="1.5" fill="#faf3df" stroke="#f0c855" stroke-width="1"/>
                  <text x="2" y="7" font-family="Playfair Display, serif" font-weight="700" font-size="6" fill="#0c0c0c">Q</text>
                  <text x="2" y="14" font-size="5" fill="#0c0c0c">♣</text>
                </g>
                <g transform="translate(68 26)">
                  <rect width="13" height="20" rx="1.5" fill="#faf3df"/>
                  <text x="2" y="7" font-family="Playfair Display, serif" font-weight="700" font-size="6" fill="#0c0c0c">7</text>
                  <text x="2" y="14" font-size="5" fill="#0c0c0c">♦</text>
                </g>
                <g transform="translate(83 26)">
                  <rect width="13" height="20" rx="1.5" fill="#faf3df"/>
                  <text x="2" y="7" font-family="Playfair Display, serif" font-weight="700" font-size="6" fill="#0c0c0c">2</text>
                  <text x="2" y="14" font-size="5" fill="#0c0c0c">♣</text>
                </g>
                {/* HOLD label under center */}
                <text x="60" y="56" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="5" fill="#f0c855" letter-spacing="2">HOLD</text>
                {/* payout strip */}
                <rect x="20" y="62" width="80" height="4" fill="#082619"/>
                <text x="60" y="65.5" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="3" fill="#f0c855" letter-spacing="1.5">PAIR · TWO PAIR · FLUSH</text>
                {/* button row */}
                <g transform="translate(20 78)">
                  <circle cx="6" cy="6" r="5" fill="#c9302c" stroke="#d4af37" stroke-width="0.6"/>
                  <circle cx="22" cy="6" r="5" fill="#c9302c" stroke="#d4af37" stroke-width="0.6"/>
                  <circle cx="38" cy="6" r="5" fill="#c9302c" stroke="#d4af37" stroke-width="0.6"/>
                  <circle cx="54" cy="6" r="5" fill="#c9302c" stroke="#d4af37" stroke-width="0.6"/>
                  <circle cx="70" cy="6" r="5" fill="#f0c855" stroke="#d4af37" stroke-width="0.6"/>
                </g>
                <text x="60" y="105" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="6" fill="#f0c855" letter-spacing="3">JACKS OR BETTER</text>
              </svg>
            )}
          </div>

          <span class="eyebrow self-start">{tag}</span>
          <h3 class="display text-xl text-parchment mt-1">{name}</h3>
          <p class="text-sm text-parchment-soft leading-relaxed flex-1">{blurb}</p>
          <span class="mono text-xs text-gold-bright mt-2">Play &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16" aria-label="Recent activity">
    <div class="flex items-end justify-between mb-3">
      <div>
        <span class="eyebrow">Live Wire</span>
        <h2 class="display text-2xl text-parchment mt-2">Recent activity</h2>
      </div>
      <a href="/hands" class="mono text-xs text-parchment-soft hover:text-gold-bright">All hands &rarr;</a>
    </div>
    <div class="panel p-4 sm:p-5" id="lobby-activity">
      <p class="text-sm text-parchment-soft text-center py-6" id="lobby-activity-empty">
        No hands yet &mdash; play one above.
      </p>
      <ul class="divide-y divide-gold-deep/20 hidden" id="lobby-activity-list"></ul>
    </div>
  </section>

  <script>
    import { getBalance, resetBankroll, formatChips, getUser } from '../../lib/bankroll.js';
    import { getAllHistory } from '../../lib/history.js';
    import { play } from '../../lib/sounds.js';
    import { toast } from '../../lib/toast.js';

    const GAME_NAMES = {
      holdem: "Texas Hold'em",
      blackjack: 'Blackjack',
      'five-card-draw': 'Five-Card Draw',
      'video-poker': 'Video Poker',
    };

    const balanceEl = document.getElementById('lobby-balance');
    const resetBtn = document.getElementById('lobby-reset');
    const userLine = document.getElementById('lobby-user-line');
    const activityEmpty = document.getElementById('lobby-activity-empty');
    const activityList = document.getElementById('lobby-activity-list');

    function renderBalance(bal) {
      if (balanceEl) balanceEl.textContent = formatChips(bal);
    }

    function renderUser() {
      const u = getUser();
      if (u?.name && userLine) userLine.textContent = `Welcome back, ${u.name}`;
    }

    function timeAgo(t) {
      const s = Math.max(0, Math.floor((Date.now() - t) / 1000));
      if (s < 30) return 'just now';
      if (s < 60) return `${s}s ago`;
      const m = Math.floor(s / 60);
      if (m < 60) return `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h}h ago`;
      const d = Math.floor(h / 24);
      return `${d}d ago`;
    }

    function renderActivity() {
      const all = getAllHistory();
      const flat = [];
      for (const game of Object.keys(all)) {
        const list = Array.isArray(all[game]) ? all[game] : [];
        for (const e of list) flat.push({ ...e, game });
      }
      flat.sort((a, b) => (b.t || 0) - (a.t || 0));
      const top = flat.slice(0, 5);

      if (top.length === 0) {
        if (activityList) activityList.classList.add('hidden');
        if (activityEmpty) activityEmpty.classList.remove('hidden');
        return;
      }

      if (activityEmpty) activityEmpty.classList.add('hidden');
      if (!activityList) return;
      activityList.classList.remove('hidden');
      activityList.innerHTML = '';

      for (const e of top) {
        const li = document.createElement('li');
        li.className = 'grid grid-cols-[1fr_auto_auto] gap-3 sm:gap-5 items-center py-2.5';

        const left = document.createElement('div');
        left.className = 'min-w-0';
        const gameName = document.createElement('p');
        gameName.className = 'mono text-sm text-parchment truncate';
        gameName.textContent = GAME_NAMES[e.game] || e.game;
        const meta = document.createElement('p');
        meta.className = 'mono text-[0.65rem] text-parchment-dim tracking-widest uppercase mt-0.5';
        meta.textContent = timeAgo(e.t || Date.now());
        left.appendChild(gameName);
        left.appendChild(meta);

        const result = document.createElement('span');
        const r = (e.result || '').toLowerCase();
        result.className = 'mono text-xs uppercase tracking-widest';
        if (r === 'win' || r === 'won') { result.classList.add('win'); result.textContent = 'WIN'; }
        else if (r === 'lose' || r === 'lost' || r === 'loss') { result.classList.add('loss'); result.textContent = 'LOSS'; }
        else if (r === 'push' || r === 'tie') { result.style.color = 'var(--color-parchment-soft)'; result.textContent = 'PUSH'; }
        else { result.style.color = 'var(--color-parchment-soft)'; result.textContent = (e.result || '—').toUpperCase(); }

        const delta = document.createElement('span');
        delta.className = 'mono text-sm';
        const d = Number(e.delta);
        if (Number.isFinite(d)) {
          if (d > 0) { delta.classList.add('win'); delta.textContent = '+' + formatChips(d); }
          else if (d < 0) { delta.classList.add('loss'); delta.textContent = '-' + formatChips(Math.abs(d)); }
          else { delta.style.color = 'var(--color-parchment-soft)'; delta.textContent = formatChips(0); }
        } else {
          delta.style.color = 'var(--color-parchment-dim)';
          delta.textContent = '—';
        }

        li.appendChild(left);
        li.appendChild(result);
        li.appendChild(delta);
        activityList.appendChild(li);
      }
    }

    // Initial paint
    renderBalance(getBalance());
    renderUser();
    renderActivity();

    // Reset button
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        const next = resetBankroll();
        renderBalance(next);
        try { play('chip'); } catch (_) {}
        toast('Bankroll reset to $1,000');
      });
    }

    // Live updates from other tabs / pages
    window.addEventListener('chipshot:bankroll', (e) => {
      renderBalance(e.detail?.balance ?? getBalance());
    });
    window.addEventListener('chipshot:history', () => renderActivity());
    window.addEventListener('chipshot:user', () => renderUser());
    window.addEventListener('storage', (e) => {
      if (!e.key) return;
      if (e.key.startsWith('chipshot.bankroll')) renderBalance(getBalance());
      if (e.key.startsWith('chipshot.history')) renderActivity();
      if (e.key.startsWith('chipshot.user')) renderUser();
    });
  </script>
</PokerLayout>
