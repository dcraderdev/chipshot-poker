---
import PokerLayout from '../layouts/PokerLayout.astro';
---
<PokerLayout
  title="Hand History — ChipShot Poker"
  description="Every hand you've played."
  active="hands"
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-14">
    <div>
      <span class="eyebrow">Journal</span>
      <h1 class="display text-3xl sm:text-4xl text-parchment mt-3">Your Hands</h1>
      <p class="text-parchment-soft text-sm mt-2 max-w-xl">
        Every hand from every game, kept locally on this device. The last 50 per game.
      </p>
    </div>
    <div class="gold-rule mt-6"></div>
  </section>

  <!-- FILTER CHIPS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Filter by game" id="filter-row">
      <button class="cs-pill is-active" data-filter="all" role="tab" aria-selected="true">All</button>
      <button class="cs-pill" data-filter="holdem" role="tab" aria-selected="false">Hold'em</button>
      <button class="cs-pill" data-filter="blackjack" role="tab" aria-selected="false">Blackjack</button>
      <button class="cs-pill" data-filter="five-card-draw" role="tab" aria-selected="false">Five-Card Draw</button>
      <button class="cs-pill" data-filter="video-poker" role="tab" aria-selected="false">Video Poker</button>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-5">
    <dl class="grid grid-cols-3 gap-px panel overflow-hidden" id="stat-strip">
      <div class="px-4 py-3">
        <dt class="stat-label">Hands</dt>
        <dd class="mono text-lg text-parchment mt-1" id="stat-count">0</dd>
      </div>
      <div class="px-4 py-3 border-l border-gold-deep/30">
        <dt class="stat-label">Net</dt>
        <dd class="mono text-lg mt-1" id="stat-net">$0</dd>
      </div>
      <div class="px-4 py-3 border-l border-gold-deep/30">
        <dt class="stat-label">Win rate</dt>
        <dd class="mono text-lg text-parchment mt-1" id="stat-winrate">—</dd>
      </div>
    </dl>
  </section>

  <!-- LIST -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 pb-20">
    <div id="history-list" class="space-y-3" aria-live="polite"></div>

    <!-- Empty state (hidden when list has entries) -->
    <div id="history-empty" class="panel p-8 text-center hidden">
      <p class="display text-2xl text-gold-bright">No hands logged yet</p>
      <p class="text-parchment-soft mt-2 text-sm">
        Sit down at a table to start your journal.
      </p>
      <p class="mt-5">
        <a href="/games" class="btn-gold">Head to the lobby</a>
      </p>
    </div>

    <div class="mt-10 text-center">
      <button id="clear-history" type="button"
        class="mono text-xs text-parchment-dim hover:text-loss underline-offset-4 hover:underline transition-colors">
        Clear all hand history
      </button>
    </div>
  </section>

  <style is:global>
    .cs-pill.is-active {
      color: var(--color-gold-bright);
      border-color: var(--color-gold);
      background: rgba(20, 50, 36, 0.85);
    }
    .hh-row { transition: border-color .15s ease; }
    .hh-row[open] { border-color: var(--color-gold-deep); }
    .hh-row summary { list-style: none; cursor: pointer; }
    .hh-row summary::-webkit-details-marker { display: none; }
    .hh-cards { display: flex; flex-wrap: wrap; gap: 8px; }
    .hh-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border: 1px solid currentColor;
      border-radius: 4px;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .hh-chevron { transition: transform .2s ease; }
    .hh-row[open] .hh-chevron { transform: rotate(90deg); }
  </style>

  <script>
    import { getAllHistory, clearAll } from '../lib/history.js';
    import { renderCard } from '../lib/card-svg.js';
    import { formatChips } from '../lib/bankroll.js';
    import { toast } from '../lib/toast.js';

    const GAME_LABELS = {
      holdem: "Hold'em",
      blackjack: "Blackjack",
      'five-card-draw': "Five-Card Draw",
      'video-poker': "Video Poker",
    };

    function labelFor(key) {
      return GAME_LABELS[key] || key.replace(/[-_]/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    }

    function timeAgo(t) {
      if (!t) return '';
      const diff = Date.now() - t;
      const s = Math.max(1, Math.floor(diff / 1000));
      if (s < 60) return s + 's ago';
      const m = Math.floor(s / 60);
      if (m < 60) return m + 'm ago';
      const h = Math.floor(m / 60);
      if (h < 24) return h + 'h ago';
      const d = Math.floor(h / 24);
      if (d < 7) return d + 'd ago';
      const dt = new Date(t);
      return dt.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
    }

    function normalizeResult(r) {
      if (!r) return 'push';
      const s = String(r).toLowerCase();
      if (s === 'win' || s === 'blackjack') return 'win';
      if (s === 'lose' || s === 'loss' || s === 'bust') return 'lose';
      if (s === 'push' || s === 'tie' || s === 'draw') return 'push';
      return s;
    }

    function resultLabel(raw) {
      const s = String(raw || '').toLowerCase();
      if (s === 'blackjack') return 'Blackjack';
      if (s === 'win') return 'Win';
      if (s === 'lose' || s === 'loss') return 'Loss';
      if (s === 'push' || s === 'tie' || s === 'draw') return 'Push';
      return raw || '—';
    }

    function deltaText(n) {
      const v = Number(n) || 0;
      if (v === 0) return formatChips(0);
      const sign = v > 0 ? '+' : '−';
      return sign + formatChips(Math.abs(v));
    }

    function getCards(entry) {
      // Be flexible about field names games may write.
      return entry.hand || entry.cards || entry.playerHand || entry.hole || [];
    }
    function getBoard(entry) {
      return entry.board || entry.community || [];
    }
    function getOpponent(entry) {
      return entry.opponentHand || entry.opponent || entry.dealerHand || entry.villain || [];
    }

    function flatten(all, filter) {
      const out = [];
      for (const game of Object.keys(all)) {
        if (filter !== 'all' && filter !== game) continue;
        const list = Array.isArray(all[game]) ? all[game] : [];
        for (const e of list) {
          out.push({ ...e, game });
        }
      }
      out.sort((a, b) => (Number(b.t) || 0) - (Number(a.t) || 0));
      return out;
    }

    function renderCards(cards) {
      if (!Array.isArray(cards) || cards.length === 0) return '';
      return `<div class="hh-cards">${cards.map((c) => renderCard(c, { small: true })).join('')}</div>`;
    }

    function renderRow(entry, idx) {
      const result = normalizeResult(entry.result);
      const delta = Number(entry.delta) || 0;
      const isWin = result === 'win' || delta > 0;
      const isLose = result === 'lose' || (delta < 0 && result !== 'push');
      const resultClass = isWin ? 'win' : isLose ? 'loss' : 'text-parchment-soft';
      const summary = entry.summary || (isWin ? 'Won the hand.' : isLose ? 'Lost the hand.' : 'Push.');

      const hand = getCards(entry);
      const board = getBoard(entry);
      const opp = getOpponent(entry);
      const hasCards = (hand && hand.length) || (board && board.length) || (opp && opp.length);

      const safeId = 'hh-' + idx;

      return `
<details class="panel hh-row" id="${safeId}">
  <summary class="block p-4 sm:p-5">
    <div class="flex items-center justify-between gap-3">
      <span class="mono text-xs text-gold uppercase tracking-widest">${labelFor(entry.game)}</span>
      <span class="mono text-xs text-parchment-dim">${timeAgo(entry.t)}</span>
    </div>
    <div class="mt-3 flex items-start justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-3 flex-wrap min-w-0">
        <span class="hh-badge ${resultClass}">${resultLabel(entry.result)}</span>
        <span class="mono text-lg ${resultClass}">${deltaText(delta)}</span>
      </div>
      <div class="text-parchment-soft text-sm sm:text-base flex-1 min-w-0 text-right">
        ${escapeHtml(summary)}
      </div>
    </div>
    ${hasCards ? `
    <div class="mt-3 flex items-center gap-2 text-gold-bright mono text-xs">
      <span class="hh-chevron">&rsaquo;</span>
      <span>View hand</span>
    </div>` : ''}
  </summary>
  ${hasCards ? `
  <div class="px-4 sm:px-5 pb-5 -mt-1 border-t border-gold-deep/20 pt-4 space-y-4">
    ${hand && hand.length ? `
      <div>
        <p class="stat-label">Your hand</p>
        <div class="mt-2">${renderCards(hand)}</div>
      </div>` : ''}
    ${board && board.length ? `
      <div>
        <p class="stat-label">Board</p>
        <div class="mt-2">${renderCards(board)}</div>
      </div>` : ''}
    ${opp && opp.length ? `
      <div>
        <p class="stat-label">Opponent</p>
        <div class="mt-2">${renderCards(opp)}</div>
      </div>` : ''}
  </div>` : ''}
</details>`;
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[c]));
    }

    const listEl = document.getElementById('history-list');
    const emptyEl = document.getElementById('history-empty');
    const countEl = document.getElementById('stat-count');
    const netEl = document.getElementById('stat-net');
    const winrateEl = document.getElementById('stat-winrate');
    const filterRow = document.getElementById('filter-row');
    const clearBtn = document.getElementById('clear-history');

    let currentFilter = 'all';

    function render() {
      const all = getAllHistory() || {};
      const entries = flatten(all, currentFilter);

      // Stats
      const count = entries.length;
      let net = 0;
      let wins = 0;
      for (const e of entries) {
        net += Number(e.delta) || 0;
        const r = normalizeResult(e.result);
        if (r === 'win') wins++;
      }
      countEl.textContent = String(count);
      netEl.textContent = (net > 0 ? '+' : net < 0 ? '−' : '') + formatChips(Math.abs(net));
      netEl.classList.remove('win', 'loss', 'text-parchment');
      netEl.classList.add(net > 0 ? 'win' : net < 0 ? 'loss' : 'text-parchment');
      winrateEl.textContent = count > 0 ? Math.round((wins / count) * 100) + '%' : '—';

      // List
      if (count === 0) {
        listEl.innerHTML = '';
        emptyEl.classList.remove('hidden');
      } else {
        emptyEl.classList.add('hidden');
        listEl.innerHTML = entries.map((e, i) => renderRow(e, i)).join('');
      }
    }

    // Filter chips
    filterRow.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-filter]');
      if (!btn) return;
      const f = btn.getAttribute('data-filter');
      if (f === currentFilter) return;
      currentFilter = f;
      for (const b of filterRow.querySelectorAll('[data-filter]')) {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      }
      render();
    });

    // Clear history
    clearBtn.addEventListener('click', () => {
      if (!confirm('Clear all hand history? This cannot be undone.')) return;
      clearAll();
      render();
      toast('Hand history cleared.');
    });

    // Live updates when a game records a new hand (same tab, custom event).
    window.addEventListener('chipshot:history', () => render());
    // Cross-tab updates via storage event.
    window.addEventListener('storage', (e) => {
      if (e.key === 'chipshot.history.v1') render();
    });
    // Re-render on focus (covers navigation back from a game page).
    window.addEventListener('focus', () => render());
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') render();
    });

    render();
  </script>
</PokerLayout>
